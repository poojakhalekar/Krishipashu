# Port the Vite dev server / preview binds to
PORT=3000

# Base path the app is served under (use "/" for root)
BASE_PATH=/

# Local dev only: API server port (used by the dev proxy)
API_PORT=8080

# OPTIONAL: Public URL where the app is deployed.
# Used to build QR-code scan links so they point at your real domain
# (e.g. https://krishipashu.yourdomain.com) instead of the local/preview URL.
# Leave blank to fall back to the browser's current origin.
VITE_PUBLIC_BASE_URL=
